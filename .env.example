# Server-side env vars. These are read by the /api/* Vercel functions
# in production, and by the Vite dev plugin during `npm run dev`. They
# are NEVER bundled into the client — they live only on the serverless
# function side.
#
# Set these in the Vercel dashboard (or `vercel env add`) for prod,
# and in a local `.env` file for development.

ELEVENLABS_API_KEY=
OPENAI_API_KEY=
