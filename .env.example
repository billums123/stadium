# Paste your ElevenLabs API key here. Because this is a Vite static
# build, the key is bundled into the client. That's fine for a hackathon
# demo on a throwaway URL; for a real deployment proxy the key through a
# serverless function instead.
VITE_ELEVENLABS_API_KEY=

# OpenAI API key for dynamic LLM-generated commentary (optional).
# When present, every line is generated fresh by GPT-5.4-mini with the
# current motion/goal/transcript state as context. When absent, the app
# falls back to the built-in template engine and still works fully.
VITE_OPENAI_API_KEY=
